APP_NAME=Agent Tracker API
ENV=dev
DATABASE_URL=postgresql+psycopg://agent_tracker:agent_tracker@db:5432/agent_tracker
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOW_MOCK_AUTH=true
# When true, only pre-existing users (e.g. synced from Google Workspace) can log in.
# Set to false to auto-create agent accounts for any Google sign-in.
RESTRICT_LOGIN_TO_KNOWN_USERS=true
CREATE_TABLES_ON_STARTUP=false
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
GOOGLE_CLIENT_ID=changeme.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# Fernet key for encrypting Google Workspace refresh tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Google Workspace domain for directory user sync (e.g. "ktenas.cloud")
GOOGLE_WORKSPACE_DOMAIN=
# Google Cloud Identity Platform (Firebase Auth) — primary sign-in for production
FIREBASE_AUTH_ENABLED=true
# GCP project ID — used by Firebase Admin SDK when ADC cannot auto-detect the project
FIREBASE_PROJECT_ID=your-gcp-project-id
# Optional: path to a service account JSON key file (leave blank to use Application Default Credentials)
# Local dev without a key: run `gcloud auth application-default login --project=your-gcp-project-id`
FIREBASE_CREDENTIALS_PATH=
